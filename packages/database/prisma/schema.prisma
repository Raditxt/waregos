generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUM DEFINITIONS
// ============================================

enum Role {
  ADMIN
  CASHIER
}

enum TransactionStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum StockMovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL
  CANCELLED
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CASHIER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions Transaction[]
  purchases    Purchase[]
  adjustments  StockMovement[]

  @@map("users")
}

// ============================================
// PRODUCT CATALOG
// ============================================

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")

  products  Product[]

  @@map("categories")
}

model Unit {
  id        String    @id @default(uuid())
  name      String    @unique
  symbol    String    @unique

  products  Product[]

  @@map("units")
}

model Product {
  id               String   @id @default(uuid())
  name             String
  sku              String?  @unique
  barcode          String?  @unique
  categoryId       String?  @map("category_id")
  unitId           String   @map("unit_id")
  buyPrice         Decimal  @map("buy_price") @db.Decimal(12, 2)
  sellPrice        Decimal  @map("sell_price") @db.Decimal(12, 2)
  stock            Int      @default(0)
  minStock         Int      @default(5) @map("min_stock")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  category         Category?       @relation(fields: [categoryId], references: [id])
  unit             Unit            @relation(fields: [unitId], references: [id])
  transactionItems TransactionItem[]
  stockMovements   StockMovement[]
  purchaseItems    PurchaseItem[]

  @@index([barcode])
  @@index([categoryId])
  @@index([name])
  @@map("products")
}

// ============================================
// TRANSACTIONS (PENJUALAN / POS)
// ============================================

model Transaction {
  id            String            @id @default(uuid())
  invoiceNumber String            @unique @map("invoice_number")
  userId        String            @map("user_id")
  status        TransactionStatus @default(COMPLETED)
  paymentMethod PaymentMethod     @default(CASH) @map("payment_method")
  totalAmount   Decimal           @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal           @map("paid_amount") @db.Decimal(12, 2)
  changeAmount  Decimal           @map("change_amount") @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")

  user          User              @relation(fields: [userId], references: [id])
  items         TransactionItem[]
  stockMovements StockMovement[]

  @@index([createdAt])
  @@index([userId])
  @@index([invoiceNumber])
  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String      @map("transaction_id")
  productId     String      @map("product_id")
  quantity      Int
  buyPrice      Decimal     @map("buy_price") @db.Decimal(12, 2)
  sellPrice     Decimal     @map("sell_price") @db.Decimal(12, 2)
  subtotal      Decimal     @db.Decimal(12, 2)

  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@map("transaction_items")
}

// ============================================
// SUPPLIER & PEMBELIAN (RESTOK)
// ============================================

model Supplier {
  id        String     @id @default(uuid())
  name      String
  phone     String?
  address   String?
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")

  purchases Purchase[]

  @@map("suppliers")
}

model Purchase {
  id            String         @id @default(uuid())
  invoiceNumber String         @unique @map("invoice_number")
  supplierId    String?        @map("supplier_id")
  userId        String         @map("user_id")
  status        PurchaseStatus @default(RECEIVED)
  totalAmount   Decimal        @map("total_amount") @db.Decimal(12, 2)
  notes         String?
  purchasedAt   DateTime       @default(now()) @map("purchased_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  items         PurchaseItem[]
  stockMovements StockMovement[]

  @@index([purchasedAt])
  @@map("purchases")
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String   @map("purchase_id")
  productId  String   @map("product_id")
  quantity   Int
  buyPrice   Decimal  @map("buy_price") @db.Decimal(12, 2)
  subtotal   Decimal  @db.Decimal(12, 2)

  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

// ============================================
// STOCK MOVEMENTS (AUDIT TRAIL STOK)
// ============================================

model StockMovement {
  id            String            @id @default(uuid())
  productId     String            @map("product_id")
  type          StockMovementType
  quantity      Int
  stockBefore   Int               @map("stock_before")
  stockAfter    Int               @map("stock_after")
  transactionId String?           @map("transaction_id")
  purchaseId    String?           @map("purchase_id")
  userId        String            @map("user_id")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")

  product       Product           @relation(fields: [productId], references: [id])
  transaction   Transaction?      @relation(fields: [transactionId], references: [id])
  purchase      Purchase?         @relation(fields: [purchaseId], references: [id])
  user          User              @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}